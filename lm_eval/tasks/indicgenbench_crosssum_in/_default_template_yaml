# Base config for google/IndicGenBench_crosssum_in
# Each language config includes this file and overrides task, process_docs, and doc_to_text.
task: null
dataset_path: google/IndicGenBench_crosssum_in
dataset_kwargs:
  field: "examples"
output_type: generate_until
validation_split: validation
fewshot_split: validation
fewshot_config:
  sampler: first_n
doc_to_text: null
doc_to_target: "{{summary}}"
generation_kwargs:
  until:
    - "\n\n"
  do_sample: false
  temperature: 0.0
  max_gen_toks: 256
target_delimiter: " "
metric_list:
  - metric: !function utils.rouge_l
    aggregation: !function utils.agg_rouge_l
    higher_is_better: true
metadata:
  version: 1.0
