# Base config for ai4bharat/IndicQA
# Each language config includes this file and overrides task name, dataset_name, and doc_to_text.
task: null
dataset_path: ai4bharat/IndicQA
dataset_name: null
output_type: generate_until
test_split: test
dataset_kwargs:
  trust_remote_code: true
doc_to_text: null
doc_to_target: "{{answers.text[0]}}"
process_results: !function utils.process_results_qa
target_delimiter: " "
generation_kwargs:
  until:
    - "\n"
  do_sample: false
  temperature: 0.0
metric_list:
  - metric: exact_match
    aggregation: mean
    higher_is_better: true
  - metric: f1
    aggregation: mean
    higher_is_better: true
metadata:
  version: 1.0
